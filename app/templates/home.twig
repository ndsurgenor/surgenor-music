{% extends 'base.twig' %}
{% block title %}Worship Songs & Resources | Surgenor Music{% endblock %}

{% block content %}

{# HERO #}
<section class="relative flex items-end justify-center bg-black/85 overflow-hidden h-[550px] sm:h-[600px] lg:h-[750px]">
    {# VIDEO / IMAGE #}
    <div class="absolute inset-0 mx-auto left-1/2 -translate-x-1/2 w-full">
        <video autoplay muted loop playsinline poster="/assets/images/hero.png"
               class="w-full h-full object-cover">
            <source src="/assets/videos/hero.webm" type="video/webm">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-charcoal/75 to-navy/85"></div>
    </div>
    {# TEXT & CTAs #}
    <div class="absolute z-10 text-center text-white px-6 mx-auto pb-16 sm:pb-20 lg:pb-28 bottom-0">
        {# Main text #}
        <h1 class="hero-text font-hero text-3xl th:text-4xl sm:text-5xl ![line-height:1.15] tracking-wide">
            <span class="text-secondary text-4xl th:text-5xl sm:text-6xl">W</span>orship
            <span class="font-semibold">Songs</span> + <span class="font-semibold">Resources</span><br>
            <span class="font-light">for the local church</span>
        </h1>
        {# Secondary text #}
        <h2 class="text-base sm:text-lg md:text-xl ![line-height:1.15] mt-3 sm:mt-4 text-gray-300">
            from musician <span class="font-semibold">Nathan Surgenor</span>
        </h2>
        {# Buttons #}
        <div class="flex flex-wrap items-center justify-center gap-4 mt-6 sm:mt-8 lg:mt-10">
            <a href="/songs" class="btn-primary-lg">Song Catalogue</a>
            <a href="/contact" class="btn-accent-outline-lg">Contact Us</a>
        </div>
    </div>
</section>

{# FEATURED SONGS #}
{% if featured %}
<section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">Featured Songs</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {% for song in featured %}
        <a href="/songs/{{ song.slug }}" class="card hover:border-primary hover:shadow-sm transition-all group">
            <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors mb-1">
                {{ song.title }}
            </h3>
            {% if song.song_key %}
            <p class="text-sm text-gray-500">Key of {{ song.song_key }}</p>
            {% endif %}
            {% if song.tags %}
            <div class="flex flex-wrap gap-1 mt-3">
                {% for tag in song.tags %}
                <span class="tag-badge">{{ tag.name }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </a>
        {% endfor %}
    </div>
    <div class="mt-8">
        <a href="/songs" class="btn-primary text-sm">View All Songs</a>
    </div>
</section>
{% endif %}

{% endblock %}
