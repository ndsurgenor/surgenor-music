{% extends 'base.twig' %}
{% block title %}Worship Resources | Surgenor Music{% endblock %}

{% block content %}

{# HERO #}
<section class="relative min-h-[600px] flex items-end justify-center">
    {# Musical staff — 5 accent lines, slightly angled, sit behind image and show on wings at 2xl+ #}
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute inset-y-0 left-[-10%] right-[-10%] -rotate-[-1deg] origin-center">
            <div class="absolute top-[40%] inset-x-0 h-[4px] bg-accent/50"></div>
            <div class="absolute top-[45%] inset-x-0 h-[3px] bg-accent/75"></div>
            <div class="absolute top-[50%] inset-x-0 h-[4px] bg-accent/50"></div>
            <div class="absolute top-[55%] inset-x-0 h-[4px] bg-accent/50"></div>
            <div class="absolute top-[60%] inset-x-0 h-[3px] bg-accent/75"></div>
        </div>
    </div>
    {# Image — capped at 2xl, centred; at 2xl+ edges fade into dark bg revealing the staff on the wings #}
    <div class="absolute inset-y-0 left-1/2 -translate-x-1/2 w-full max-w-screen-2xl overflow-hidden">
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('{{ hero_image ? '/assets/images/' ~ hero_image : '/assets/images/hero.jpg' }}')"></div>
        <div class="absolute inset-0 bg-black/15"></div>
    </div>
    {# Text & CTAs #}
    <div class="relative z-10 text-center text-white px-6 max-w-3xl mx-auto py-20 rounded-lg">
        <h1 class="hero-text text-3xl md:text-4xl font-light leading-tight">
            {{ hero_text|raw }}
        </h1>
        <div class="flex flex-wrap items-center justify-center gap-4 mt-10">
            <a href="/songs" class="btn-primary-lg">Song Catalogue</a>
            <a href="/contact" class="btn-accent-outline-lg">Contact Us</a>
        </div>
    </div>
</section>

{# FEATURED SONGS #}
{% if featured %}
<section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-8">Featured Songs</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {% for song in featured %}
        <a href="/songs/{{ song.slug }}" class="card hover:border-primary hover:shadow-sm transition-all group">
            <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors mb-1">
                {{ song.title }}
            </h3>
            {% if song.song_key %}
            <p class="text-sm text-gray-500">Key of {{ song.song_key }}</p>
            {% endif %}
            {% if song.tags %}
            <div class="flex flex-wrap gap-1 mt-3">
                {% for tag in song.tags %}
                <span class="tag-badge">{{ tag.name }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </a>
        {% endfor %}
    </div>
    <div class="mt-8">
        <a href="/songs" class="btn-primary">View All Songs</a>
    </div>
</section>
{% endif %}

{% endblock %}
