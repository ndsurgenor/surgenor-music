{% extends 'base.twig' %}

{% block title %}Media | Surgenor Music{% endblock %}
{% block meta_description %}Discography and online recordings from Surgenor Music — worship songs on YouTube, Spotify, and more.{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-6 py-12">

    {# HEADER #}
    <div class="mb-12">
        <h1 class="text-3xl font-bold text-gray-900 mb-3">Media</h1>
        <p class="text-gray-500 text-lg leading-relaxed">
            Recordings, music videos, and the full discography for Surgenor Music worship songs —
            available to stream and watch online.
        </p>
    </div>

    {# DISCOGRAPHY #}
    <section class="mb-14">
        <h2 class="text-xl font-semibold text-gray-900 mb-1">Discography</h2>
        <p class="text-gray-500 mb-8">Full catalogue of releases available to stream on Spotify.</p>

        {#
            Add a release card for each album / EP / single by duplicating the block below.
            Replace the title, year, type, and href as needed.
        #}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

            {# RELEASE CARD — duplicate and edit for each release #}
            <a href="#" class="card flex items-center gap-5 hover:border-primary hover:shadow-sm transition-all group">
                {# Artwork placeholder — swap the div for an <img> once artwork is available #}
                <div class="w-16 h-16 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                    <svg class="w-7 h-7 text-primary/60" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-900 group-hover:text-primary transition-colors">Release Title</h3>
                    <p class="text-sm text-gray-500 mt-0.5">Year &middot; EP / Album / Single</p>
                </div>
            </a>

        </div>
    </section>

    {# WATCH & LISTEN ONLINE #}
    <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-1">Watch &amp; Listen Online</h2>
        <p class="text-gray-500 mb-8">Find full recordings and music videos on the platforms below.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

            {# YouTube #}
            <a href="https://www.youtube.com/@surgenormusic" target="_blank" rel="noopener noreferrer"
               class="card flex items-center gap-5 hover:border-red-400/60 hover:shadow-sm transition-all group">
                <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center shrink-0">
                    <svg class="w-7 h-7 text-red-500/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-900 group-hover:text-red-500/80 transition-colors">YouTube</h3>
                    <p class="text-sm text-gray-500 mt-0.5">Music videos and live recordings</p>
                </div>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-red-400/60 ml-auto shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                </svg>
            </a>

            {# Spotify #}
            <a href="#" target="_blank" rel="noopener noreferrer"
               class="card flex items-center gap-5 hover:border-green-400/60 hover:shadow-sm transition-all group">
                <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
                    <svg class="w-6 h-6 text-green-500/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-900 group-hover:text-green-500/80 transition-colors">Spotify</h3>
                    <p class="text-sm text-gray-500 mt-0.5">Stream the full discography</p>
                </div>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-green-400/60 ml-auto shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                </svg>
            </a>

            {# Instagram #}
            <a href="https://www.instagram.com/surgenormusic/" target="_blank" rel="noopener noreferrer"
               class="card flex items-center gap-5 hover:border-rose-400/60 hover:shadow-sm transition-all group">
                <div class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center shrink-0">
                    <svg class="w-6 h-6 text-rose-500/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-900 group-hover:text-rose-500/80 transition-colors">Instagram</h3>
                    <p class="text-sm text-gray-500 mt-0.5">Behind the scenes and short clips</p>
                </div>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-rose-400/60 ml-auto shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                </svg>
            </a>

        </div>
    </section>

</div>
{% endblock %}
