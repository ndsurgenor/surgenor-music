{% extends 'admin/base.html.twig' %}

{% block title %}Songs{% endblock %}
{% block page_title %}Songs{% endblock %}

{% set active_nav = 'songs' %}

{% block content %}

<div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-500">{{ songs|length }} song{% if songs|length != 1 %}s{% endif %}</p>
    <a href="/admin/songs/create" class="btn-primary text-sm">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Song
    </a>
</div>

{% if songs %}
<div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
    <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
                <th class="text-left px-5 py-3 font-semibold text-gray-700">Title</th>
                <th class="text-left px-5 py-3 font-semibold text-gray-700 hidden sm:table-cell">Key</th>
                <th class="text-left px-5 py-3 font-semibold text-gray-700 hidden md:table-cell">Featured</th>
                <th class="px-5 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for song in songs %}
            <tr class="hover:bg-gray-50">
                <td class="px-5 py-4 font-medium text-gray-900">{{ song.title }}</td>
                <td class="px-5 py-4 text-gray-500 hidden sm:table-cell">
                    {% if song.song_key %}{{ song.song_key }}{% else %}—{% endif %}
                </td>
                <td class="px-5 py-4 hidden md:table-cell">
                    {% if song.featured %}
                    <span class="tag-badge">Yes</span>
                    {% else %}
                    <span class="text-gray-400">No</span>
                    {% endif %}
                </td>
                <td class="px-5 py-4">
                    <div class="flex items-center justify-end gap-2">
                        <a href="/songs/{{ song.slug }}" target="_blank"
                           class="text-xs text-gray-500 hover:text-primary transition-colors">View ↗</a>
                        <a href="/admin/songs/{{ song.id }}/edit" class="btn-secondary text-xs px-3 py-1.5">Edit</a>
                        <form method="POST" action="/admin/songs/{{ song.id }}/delete" class="inline">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit"
                                    class="btn-danger text-xs px-3 py-1.5"
                                    data-confirm="Delete "{{ song.title }}"? This cannot be undone.">
                                Delete
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% else %}
<div class="card text-center py-12 text-gray-500">
    <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
    </svg>
    <p class="font-medium text-gray-700 mb-4">No songs yet</p>
    <a href="/admin/songs/create" class="btn-primary">Add your first song</a>
</div>
{% endif %}

{% endblock %}
