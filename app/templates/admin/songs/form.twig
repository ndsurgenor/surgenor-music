{% extends 'admin/base.twig' %}

{% set is_edit = song and song.id is defined %}

{% block title %}{{ is_edit ? 'Edit: ' ~ song.title : 'Add Song' }}{% endblock %}
{% block page_title %}{{ is_edit ? 'Edit Song' : 'Add New Song' }}{% endblock %}

{% set active_nav = 'songs' %}

{% block content %}

{% if error %}
<div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700 mb-6">
    {{ error }}
</div>
{% endif %}

<form method="POST"
      action="{{ is_edit ? '/admin/songs/' ~ song.id ~ '/edit' : '/admin/songs/create' }}"
      enctype="multipart/form-data"
      class="space-y-8 max-w-3xl">

    <input type="hidden" name="_csrf" value="{{ csrf_token }}">

    {# BASIC DETAILS #}
    <div class="card space-y-5">
        <h2 class="font-semibold text-gray-900 text-base border-b border-gray-100 pb-3">Song Details</h2>

        <div>
            <label for="title" class="form-label">Title <span class="text-accent">*</span></label>
            <input type="text" id="title" name="title"
                   value="{{ song.title ?? '' }}"
                   required class="form-input" placeholder="Song title">
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label for="song_key" class="form-label">Key</label>
                <input type="text" id="song_key" name="song_key"
                       value="{{ song.song_key ?? '' }}"
                       class="form-input" placeholder="e.g. G, Bb, F#m">
            </div>
            <div>
                <label for="tempo" class="form-label">Tempo (BPM)</label>
                <input type="number" id="tempo" name="tempo"
                       value="{{ song.tempo ?? '' }}"
                       class="form-input" placeholder="e.g. 72" min="1" max="300">
            </div>
        </div>

        <div data-ccli-field>
            <label for="ccli_url" class="form-label">SongSelect URL</label>
            <input type="url" id="ccli_url" name="ccli_url"
                   value="{{ song.ccli_url ?? '' }}"
                   class="form-input" placeholder="https://songselect.ccli.com/songs/1234567/song-title"
                   data-ccli-url-input>

            <div class="mt-4{% if not (song.ccli_url ?? false) and not (song.ccli_number_override ?? false) %} hidden{% endif %}" data-ccli-number-wrap>
                <div class="flex items-center justify-between">
                    <label for="ccli_number_override" class="form-label mb-0">CCLI Number</label>
                    <div class="inline-flex items-center gap-2" data-ccli-mode-switch>
                        <span class="text-xs font-medium{% if song.ccli_number_override ?? false %} text-gray-700{% else %} text-gray-400{% endif %}" data-ccli-mode-label="manual">Manual</span>
                        <button type="button"
                                role="switch"
                                aria-checked="{{ (song.ccli_number_override ?? false) ? 'false' : 'true' }}"
                                class="ccli-switch{% if not (song.ccli_number_override ?? false) %} active{% endif %}"
                                data-ccli-switch>
                            <span class="ccli-switch-thumb"></span>
                        </button>
                        <span class="text-xs font-medium{% if song.ccli_number_override ?? false %} text-gray-400{% else %} text-gray-700{% endif %}" data-ccli-mode-label="auto">Auto</span>
                    </div>
                </div>
                <input type="text" id="ccli_number_override" name="ccli_number_override"
                       value="{{ song.ccli_number ?? '' }}"
                       class="form-input mt-1"
                       placeholder="e.g. 1234567"
                       {% if not (song.ccli_number_override ?? false) %}disabled{% endif %}
                       data-ccli-number-input>
            </div>
        </div>

        <div>
            <label for="tags" class="form-label">Themes / Tags</label>
            <input type="text" id="tags" name="tags"
                   value="{{ song.tags is defined ? song.tags|map(t => t.name)|join(', ') : '' }}"
                   class="form-input" placeholder="Comma-separated, e.g. Praise, Communion, Advent">
            <p class="mt-1 text-xs text-gray-500">Separate multiple tags with commas. New tags are created automatically.</p>
        </div>

        <div class="flex items-center gap-3">
            <input type="checkbox" id="featured" name="featured"
                   class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary"
                   {% if song.featured ?? false %}checked{% endif %}>
            <label for="featured" class="text-sm font-medium text-gray-700">Show on homepage as a featured song</label>
        </div>
    </div>

    {# LYRICS #}
    <div class="card space-y-4">
        <h2 class="font-semibold text-gray-900 text-base border-b border-gray-100 pb-3">Lyrics</h2>
        <div>
            <label for="lyrics" class="form-label">Lyrics</label>
            <div data-rich-toolbar>
                <div class="flex items-center gap-1 border border-gray-300 rounded-t-lg px-2 py-1.5 bg-gray-50 border-b-0">
                    <button type="button" data-command="bold"   class="rich-btn px-2 py-1 text-sm rounded hover:bg-gray-200"><strong>B</strong></button>
                    <button type="button" data-command="italic" class="rich-btn px-2 py-1 text-sm rounded hover:bg-gray-200"><em>I</em></button>
                    <div class="w-px h-5 bg-gray-300 mx-1"></div>
                    <button type="button" data-command="removeFormat" class="rich-btn px-2 py-1 text-sm rounded hover:bg-gray-200">✕</button>
                </div>
                <div contenteditable="true" data-rich-editor="lyrics"
                     class="form-input font-mono text-sm resize-y rounded-t-none min-h-[16rem]">{{ (song.lyrics ?? '')|raw }}</div>
            </div>
            <input type="hidden" name="lyrics" id="lyrics">
        </div>
    </div>

    {# COPYRIGHT #}
    <div class="card space-y-4">
        <h2 class="font-semibold text-gray-900 text-base border-b border-gray-100 pb-3">Copyright &amp; Licensing</h2>
        <div>
            <label for="copyright_info" class="form-label">Copyright information</label>
            <textarea id="copyright_info" name="copyright_info" rows="4"
                      class="form-input resize-y"
                      placeholder="e.g. Words and music by Nathan Surgenor. © 2024 Nathan Surgenor. CCLI Song #...">{{ song.copyright_info ?? '' }}</textarea>
        </div>
        <div>
            <label for="notes" class="form-label">Admin notes <span class="text-gray-400 font-normal">(not shown publicly)</span></label>
            <textarea id="notes" name="notes" rows="3"
                      class="form-input resize-y"
                      placeholder="Internal notes about this song…">{{ song.notes ?? '' }}</textarea>
        </div>
    </div>

    {# SHEET MUSIC FILES #}
    <div class="card space-y-4">
        <h2 class="font-semibold text-gray-900 text-base border-b border-gray-100 pb-3">Sheet Music (PDF)</h2>

        {% if is_edit %}
        {% set sm_files = song.files|filter(f => f.type == 'sheet_music') %}
        {% if sm_files|length %}
        <div class="space-y-2">
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Existing files</p>
            {% for file in sm_files %}
            <div class="flex items-center justify-between py-2 px-3 bg-gray-50 rounded-lg border border-gray-200 text-sm">
                <span class="text-gray-700">{{ file.label }} <span class="text-gray-400">({{ file.filename }})</span></span>
                <button type="submit" formaction="/admin/files/{{ file.id }}/delete" formmethod="POST"
                        formnovalidate class="text-red-500 hover:text-red-700 text-xs font-medium"
                        data-confirm="Remove this file?">Remove</button>
            </div>
            {% endfor %}
        </div>
        {% endif %}
        {% endif %}

        <div>
            <label class="form-label">Upload new PDF files</label>
            <input type="file" name="sheet_music[]" multiple accept=".pdf"
                   class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-primary-700 transition-colors cursor-pointer">
            <p class="mt-1 text-xs text-gray-500">You can select multiple PDF files at once.</p>
        </div>
    </div>

    {# AUDIO FILES #}
    <div class="card space-y-4">
        <h2 class="font-semibold text-gray-900 text-base border-b border-gray-100 pb-3">Audio Files</h2>

        {% if is_edit %}
        {% set audio_files = song.files|filter(f => f.type == 'audio') %}
        {% if audio_files|length %}
        <div class="space-y-2">
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Existing files</p>
            {% for file in audio_files %}
            <div class="flex items-center justify-between py-2 px-3 bg-gray-50 rounded-lg border border-gray-200 text-sm">
                <span class="text-gray-700">{{ file.label }} <span class="text-gray-400">({{ file.filename }})</span></span>
                <button type="submit" formaction="/admin/files/{{ file.id }}/delete" formmethod="POST"
                        formnovalidate class="text-red-500 hover:text-red-700 text-xs font-medium"
                        data-confirm="Remove this file?">Remove</button>
            </div>
            {% endfor %}
        </div>
        {% endif %}
        {% endif %}

        <div>
            <label class="form-label">Upload new audio files</label>
            <input type="file" name="audio[]" multiple accept="audio/*"
                   class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-primary-700 transition-colors cursor-pointer">
            <p class="mt-1 text-xs text-gray-500">Accepts MP3, WAV, M4A, FLAC and other audio formats.</p>
        </div>
    </div>

    {# ACTION BUTTONS #}
    <div class="flex items-center gap-3">
        <button type="submit" class="btn-primary">
            {{ is_edit ? 'Save Changes' : 'Create Song' }}
        </button>
        <a href="/admin/songs" class="btn-secondary">Cancel</a>
    </div>

</form>

{% endblock %}
