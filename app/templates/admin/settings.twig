{% extends 'admin/base.twig' %}

{% block title %}Homepage Settings{% endblock %}
{% block page_title %}Homepage Settings{% endblock %}

{% set active_nav = 'settings' %}

{% block content %}

<form method="POST" action="/admin/settings" enctype="multipart/form-data" class="space-y-8 max-w-3xl">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">

    {# HERO TEXT #}
    <div class="card space-y-4">
        <h2 class="font-semibold text-gray-900 text-base border-b border-gray-100 pb-3">Hero Text</h2>
        <p class="text-sm text-gray-500">This text appears over the hero image on the homepage.</p>

        {# Toolbar + editor wrapped together so the JS can scope button lookups #}
        <div data-rich-toolbar>
            <div class="flex items-center gap-1 border border-gray-300 rounded-t-lg px-2 py-1.5 bg-gray-50 border-b-0">
                <button type="button" data-command="bold"
                        class="rich-btn w-8 h-8 flex items-center justify-center rounded font-bold text-sm text-gray-700 hover:bg-gray-200 transition-colors"
                        title="Bold (Ctrl+B)"><strong>B</strong></button>
                <button type="button" data-command="italic"
                        class="rich-btn w-8 h-8 flex items-center justify-center rounded text-sm text-gray-700 hover:bg-gray-200 transition-colors"
                        title="Italic (Ctrl+I)"><em>I</em></button>
                <div class="w-px h-5 bg-gray-300 mx-1"></div>
                <button type="button" data-command="removeFormat"
                        class="rich-btn w-8 h-8 flex items-center justify-center rounded text-xs text-gray-500 hover:bg-gray-200 transition-colors"
                        title="Clear formatting">✕</button>
            </div>

            <div id="hero-editor"
                 contenteditable="true"
                 data-rich-editor="hero-text-input"
                 class="min-h-[100px] border border-gray-300 rounded-b-lg px-4 py-3 text-gray-900 text-lg leading-relaxed focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary bg-white"
            >{{ settings.hero_text|raw }}</div>
        </div>

        {# Hidden input synced on submit #}
        <input type="hidden" name="hero_text" id="hero-text-input">
    </div>

    {# HERO IMAGE #}
    <div class="card space-y-4">
        <h2 class="font-semibold text-gray-900 text-base border-b border-gray-100 pb-3">Hero Image</h2>

        {% if settings.hero_image %}
        <div class="rounded-lg overflow-hidden border border-gray-200 bg-gray-50 aspect-[16/5]">
            <img src="/assets/images/{{ settings.hero_image }}?v={{ 'now'|date('U') }}"
                 alt="Current hero image"
                 class="w-full h-full object-cover">
        </div>
        <p class="text-xs text-gray-400">Current: {{ settings.hero_image }}</p>
        {% else %}
        <p class="text-sm text-gray-500 italic">No hero image set. Upload one below.</p>
        {% endif %}

        <div>
            <label class="form-label">Upload new image</label>
            <input type="file" name="hero_image" accept=".jpg,.jpeg,.png,.webp"
                   class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary file:text-white hover:file:bg-primary-700 transition-colors cursor-pointer">
            <p class="mt-1 text-xs text-gray-500">JPG, PNG or WebP. Recommended: at least 1600px wide. Replaces the existing image.</p>
        </div>
    </div>

    <button type="submit" class="btn-primary">Save Settings</button>
</form>

{% endblock %}
