{% extends 'base.twig' %}

{% block title %}Song Catalogue | Surgenor Music{% endblock %}
{% block meta_description %}Browse and search worship songs and resources from Nathan Surgenor.{% endblock %}

{% block content %}
{# Page banner #}
<div class="relative overflow-hidden bg-navy">
    <div class="absolute inset-0 bg-gradient-to-b from-navy/75 to-primary-500/50"></div>
    <div class="relative max-w-6xl mx-auto px-6 overflow-hidden">
        <div class="absolute right-12 top-1/2 -translate-y-1/2 rotate-[30deg] font-secondary text-cream leading-none opacity-[0.07] select-none pointer-events-none" style="font-size:24rem">S</div>
        <div class="relative z-10 py-10 sm:py-14">
            <h1 class="font-hero text-3xl sm:text-4xl text-white tracking-wide">{{ page_heading }}</h1>
            <h2 class="relative pl-4 mt-3 text-gray-300 text-base sm:text-lg max-w-xl"><span class="absolute left-0.5 top-0.5 bottom-[-4px] w-[3px] bg-accent rounded-full"></span>Browse and search all available songs and their resources</h2>
        </div>
    </div>
</div>

<div class="max-w-6xl mx-auto px-6 py-12">

    {# SEARCH & FILTERS #}
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center gap-3">

            {# Search #}
            <div class="flex-1">
                <label for="q" class="sr-only">Search songs</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                    <input type="search" id="q" placeholder="Search by song title and/or CCLI#" class="form-input pl-9" autocomplete="off">
                </div>
            </div>

            {# Filter by Key #}
            {% if keys %}
            <div class="relative sm:w-40 sm:self-stretch" data-multiselect id="ms-key">
                <button type="button"
                        class="w-full h-full rounded-lg border border-gray-300 bg-white shadow-sm px-3 py-2 sm:py-0 text-left text-base font-normal flex items-center justify-between gap-2 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                        data-multiselect-trigger aria-expanded="false">
                    <span class="truncate" data-multiselect-label>All keys</span>
                    <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div class="absolute z-20 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg hidden max-h-60 overflow-y-auto"
                     data-multiselect-panel>
                    {% for k in keys %}
                    <label class="flex items-center gap-2.5 px-3 py-2 hover:bg-gray-50 cursor-pointer">
                        <input type="checkbox" value="{{ k }}" class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary shrink-0">
                        <span class="text-sm text-gray-700">{{ k }}</span>
                    </label>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Filter by Tag #}
            {% if tags %}
            <div class="relative sm:w-44 sm:self-stretch" data-multiselect id="ms-tag">
                <button type="button"
                        class="w-full h-full rounded-lg border border-gray-300 bg-white shadow-sm px-3 py-2 sm:py-0 text-left text-base font-normal flex items-center justify-between gap-2 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                        data-multiselect-trigger aria-expanded="false">
                    <span class="truncate" data-multiselect-label>All themes</span>
                    <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div class="absolute z-20 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg hidden max-h-60 overflow-y-auto"
                     data-multiselect-panel>
                    {% for tag in tags %}
                    <label class="flex items-center gap-2.5 px-3 py-2 hover:bg-gray-50 cursor-pointer">
                        <input type="checkbox" value="{{ tag.slug }}" class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary shrink-0">
                        <span class="text-sm text-gray-700">{{ tag.name }}</span>
                    </label>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <button type="button" id="song-reset" class="btn py-1.5 sm:py-0 sm:self-stretch shrink-0 border-2 border-accent bg-white hover:bg-accent/15 focus:ring-accent font-normal text-base opacity-30 pointer-events-none transition-all duration-150">
                <svg class="w-4 h-4 mr-1.5 shrink-0" style="transform:scaleX(-1)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
                </svg>
                Reset
            </button>
        </div>
    </div>

    {# RESULTS #}
    {% if songs %}
    <div class="text-sm text-gray-500 mb-4">
        <span id="song-count">{{ songs|length }} song{% if songs|length != 1 %}s{% endif %}</span>
    </div>

    <div class="border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-primary/10 border-b border-primary/20">
                <tr>
                    <th class="text-left px-5 py-3 font-semibold cursor-pointer select-none" data-sort-col="title">
                        <div class="flex items-center gap-1.5">
                            <span class="sort-label text-primary-800">Title</span>
                            <span class="flex flex-col gap-0">
                                <svg class="sort-asc w-3.5 h-3.5 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/></svg>
                                <svg class="sort-desc w-3.5 h-3.5 opacity-30 -mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </div>
                    </th>
                    <th class="text-left px-5 py-3 font-semibold hidden md:table-cell cursor-pointer select-none" data-sort-col="ccli">
                        <div class="flex items-center gap-1.5">
                            <span class="sort-label text-primary-800">CCLI#</span>
                            <span class="flex flex-col gap-0">
                                <svg class="sort-asc w-3.5 h-3.5 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/></svg>
                                <svg class="sort-desc w-3.5 h-3.5 opacity-30 -mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </div>
                    </th>
                    <th class="text-left px-5 py-3 font-semibold hidden sm:table-cell cursor-pointer select-none" data-sort-col="key">
                        <div class="flex items-center gap-1.5">
                            <span class="sort-label text-primary-800">Key</span>
                            <span class="flex flex-col gap-0">
                                <svg class="sort-asc w-3.5 h-3.5 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/></svg>
                                <svg class="sort-desc w-3.5 h-3.5 opacity-30 -mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                            </span>
                        </div>
                    </th>
                    <th class="text-left px-5 py-3 font-semibold text-primary-800 hidden md:table-cell">Themes</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody id="song-tbody" class="divide-y divide-gray-100">
                {% for song in songs %}
                <tr class="bg-white"
                    data-song-row
                    data-title="{{ song.title|lower }}"
                    data-ccli="{{ song.ccli_number ?? '' }}"
                    data-key="{{ song.song_key }}"
                    data-tags="{{ song.tags|map(t => t.slug)|join(' ') }}">
                    <td class="px-5 py-4">
                        <a href="/songs/{{ song.slug }}" class="font-medium text-gray-900 hover:text-primary transition-colors">
                            {{ song.title }}
                        </a>
                    </td>
                    <td class="px-5 py-4 hidden md:table-cell">
                        {% if song.ccli_number %}
                        <span class="text-gray-500">{{ song.ccli_number }}</span>
                        {% else %}
                        <span class="text-gray-400">Pending</span>
                        {% endif %}
                    </td>
                    <td class="px-5 py-4 text-gray-500 hidden sm:table-cell">
                        {% if song.song_key %}{{ song.song_key }}{% else %}—{% endif %}
                    </td>
                    <td class="px-5 py-4 hidden md:table-cell">
                        <div class="flex flex-wrap gap-1">
                            {% for tag in song.tags %}
                            <button type="button" data-tag-filter="{{ tag.slug }}" class="tag-badge hover:bg-primary/20 transition-colors">{{ tag.name }}</button>
                            {% endfor %}
                        </div>
                    </td>
                    <td class="px-5 py-4 text-right">
                        <a href="/songs/{{ song.slug }}" class="btn-primary text-xs px-3 py-1.5">View</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div id="song-no-results" class="text-center py-16 text-gray-500" style="display:none">
        <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
        </svg>
        <p class="font-medium text-gray-700 mb-1">No songs found</p>
        <p class="text-sm">Try adjusting your search or filters.</p>
    </div>

    {% else %}
    {# Empty catalogue — no songs added yet #}
    <div class="text-center py-16 text-gray-500">
        <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
        </svg>
        <p class="font-medium text-gray-700 mb-1">No songs yet</p>
        <p class="text-sm">Check back soon.</p>
    </div>
    {% endif %}

</div>
{% endblock %}
