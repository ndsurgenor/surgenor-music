{% extends 'base.twig' %}

{% block title %}{{ song.title }} — Surgenor Music{% endblock %}
{% block meta_description %}Sheet music, audio, and lyrics for "{{ song.title }}" by Nathan Surgenor.{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-6 py-12">

    {# BREADCRUMB #}
    <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <a href="/songs" class="hover:text-primary transition-colors">Song Catalogue</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{{ song.title }}</span>
    </nav>

    {# HEADER #}
    <div class="mb-10">
        <h1 class="text-4xl font-bold text-gray-900 mb-3">{{ song.title }}</h1>

        <div class="flex flex-wrap items-center gap-3 text-sm">
            {% if song.song_key %}
            <span class="inline-flex items-center gap-1.5 text-gray-600 font-medium">
                <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
                </svg>
                Key of {{ song.song_key }}
            </span>
            {% endif %}

            {% if song.tempo %}
            <span class="text-gray-500">{{ song.tempo }} BPM</span>
            {% endif %}

            {% for tag in song.tags %}
            <a href="/songs?tag={{ tag.slug }}" class="tag-badge">{{ tag.name }}</a>
            {% endfor %}
        </div>
    </div>

    {% set sheet_music_files = song.files|filter(f => f.type == 'sheet_music') %}
    {% set audio_files = song.files|filter(f => f.type == 'audio') %}

    {# SHEET MUSIC #}
    {% if sheet_music_files|length %}
    <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-5 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Sheet Music
        </h2>

        <div class="space-y-6">
            {% for file in sheet_music_files %}
            <div class="card">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-semibold text-gray-900">{{ file.label }}</h3>
                    <a href="/uploads/songs/{{ song.id }}/{{ file.filename }}"
                       download
                       class="btn-secondary text-xs px-3 py-1.5 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                        </svg>
                        Download
                    </a>
                </div>
                <div class="rounded-lg overflow-hidden border border-gray-200 bg-gray-50">
                    <iframe src="/uploads/songs/{{ song.id }}/{{ file.filename }}"
                            class="w-full h-[680px]"
                            title="{{ file.label }}">
                        <p class="p-4 text-sm text-gray-600">
                            Your browser cannot display this PDF.
                            <a href="/uploads/songs/{{ song.id }}/{{ file.filename }}" class="text-primary underline">Download it instead.</a>
                        </p>
                    </iframe>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {# AUDIO #}
    {% if audio_files|length %}
    <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-5 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 9v6m0 0l-3-3m3 3l3-3m-9 5a9 9 0 010-12.728"/>
            </svg>
            Audio
        </h2>

        <div class="space-y-4">
            {% for file in audio_files %}
            <div class="card">
                <p class="font-semibold text-gray-900 mb-3">{{ file.label }}</p>
                <audio controls class="w-full">
                    <source src="/uploads/songs/{{ song.id }}/{{ file.filename }}">
                    Your browser does not support audio playback.
                    <a href="/uploads/songs/{{ song.id }}/{{ file.filename }}" class="text-primary underline">Download the file.</a>
                </audio>
            </div>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {# LYRICS #}
    {% if song.lyrics %}
    <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-5 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10"/>
            </svg>
            Lyrics
        </h2>
        <div class="card">
            <div class="prose prose-sm max-w-none text-gray-700 whitespace-pre-wrap leading-relaxed">{{ song.lyrics }}</div>
        </div>
    </section>
    {% endif %}

    {# COPYRIGHT #}
    {% if song.copyright_info %}
    <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-900 mb-5 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            Copyright &amp; Licensing
        </h2>
        <div class="card text-sm text-gray-600 leading-relaxed whitespace-pre-wrap">{{ song.copyright_info }}</div>
    </section>
    {% endif %}

    {# BACK LINK #}
    <a href="/songs" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Song Catalogue
    </a>

</div>
{% endblock %}
