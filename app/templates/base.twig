<!DOCTYPE html>
<html lang="en" class="h-full">

{# HEAD #}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Surgenor Music{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Worship songs and resources from musician Nathan Surgenor.{% endblock %}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Questrial&family=Outfit:wght@400;500;600;700&family=Plaster&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/app.css">
    {% block head %}{% endblock %}
</head>

{# BODY #}
<body class="font-sans text-charcoal bg-cream flex flex-col min-h-full">

    {# NAVIGATION #}
    <header class="bg-cream border-b border-gray-100 shadow-lg sticky top-0 z-50">
        <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

            {# Branding #}
            <a href="/" class="flex items-center font-hero text-primary text-2xl sm:text-3xl tracking-tight" aria-label="Surgenor Music home">
                <span class="font-semibold mr-1">surgenor</span>
                <span class="text-secondary uppercase tracking-tighter">m</span>usic
            </a>

            {# Desktop links & icons #}
            <div class="hidden min-[925px]:flex items-center gap-8">
                <ul class="flex items-center gap-8">
                    {% for item in nav_links %}
                    <li><a href="{{ item.path }}" class="relative text-lg text-primary hover:text-charcoal transition-colors after:absolute after:left-0 after:h-[5px] after:-bottom-[8px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ (current_path == item.path or (item.path != '/' and current_path starts with item.path)) ? 'font-bold' : 'font-medium' }}">{{ item.label }}</a></li>
                    {% endfor %}
                </ul>
                <div class="w-0.5 h-5 bg-navy/30"></div>
                <div class="flex items-center gap-3">
                    <a href="https://www.instagram.com/surgenormusic/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-rose-500/65 hover:text-rose-500/95 transition-colors">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    </a>
                    <a href="#" aria-label="Spotify" class="text-green-500/65 hover:text-green-500/95 transition-colors">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                    </a>
                    <a href="https://www.youtube.com/@surgenormusic" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-red-500/65 hover:text-red-500/95 transition-colors">
                        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
                    </a>
                </div>
            </div>

            {# Mobile #}
            <button id="menu-toggle" class="min-[925px]:hidden p-1 rounded-tr-lg border-2 border-accent text-accent bg-white hover:bg-gray-100 transition-colors transition-transform duration-[250ms]" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation">
                <svg class="w-6 h-6 transition-transform duration-[250ms]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </nav>

        {# Mobile menu #}
        <div id="mobile-menu" class="min-[925px]:hidden border-t border-gray-100 bg-cream">
            <div class="max-w-6xl mx-auto px-6 py-4 space-y-3 text-right">
                {% for item in nav_links %}
                <a href="{{ item.path }}" class="relative block w-fit ml-auto text-lg text-primary hover:text-charcoal transition-colors after:absolute after:bottom-0 after:left-0 after:h-[5px] after:-bottom-[3px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ (current_path == item.path or (item.path != '/' and current_path starts with item.path)) ? 'font-bold' : 'font-medium' }} py-1">{{ item.label }}</a>
                {% endfor %}
                <div class="flex items-center justify-end gap-3 pt-3 border-t border-gray-200">
                    <a href="#" aria-label="Instagram" class="text-rose-500/65 hover:text-rose-500/95 transition-colors">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    </a>
                    <a href="#" aria-label="Spotify" class="text-green-500/65 hover:text-green-500/95 transition-colors">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                    </a>
                    <a href="#" aria-label="YouTube" class="text-red-500/65 hover:text-red-500/95 transition-colors">
                        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </header>

    {# FLASH MESSAGE #}
    {% if flash %}
    <div id="flash-message" class="{% if flash.type == 'success' %}bg-primary/10 border-primary/20 text-primary-700{% else %}bg-red-50 border-red-200 text-red-700{% endif %} border-b px-6 py-3 text-sm text-center font-medium">
        {{ flash.message }}
    </div>
    {% endif %}

    {# MAIN CONTENT #}
    <main class="flex-1">
        {% block content %}
        {% endblock %}
    </main>

    {# FOOTER #}
    <footer class="bg-gradient-to-b from-navy/95 to-primary-900 mt-16">
        <div class="max-w-6xl mx-auto px-6 py-12">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">

                {% for item in nav_links %}
                {% if item.path != '/' %}
                <div>
                    <h4 class="font-semibold text-white text-sm mb-3">{{ item.label }}</h4>
                    <ul class="space-y-2 text-sm text-gray-300">
                        <li><a href="{{ item.path }}" class="hover:text-accent transition-colors">{{ item.page_heading|default(item.label) }}</a></li>
                    </ul>
                </div>
                {% endif %}
                {% endfor %}

                <div class="md:text-right">
                    <h4 class="font-semibold text-sm mb-3 invisible hidden md:block">&nbsp;</h4>
                    <div class="flex items-center font-hero text-lg md:justify-end">
                        <span class="text-white mr-1">surgenor</span>
                        <span class="text-secondary uppercase">m</span>
                        <span class="text-white">usic</span>
                    </div>
                </div>
            </div>

            <div class="pt-6 border-t border-gray-600 text-xs text-gray-400 flex flex-wrap items-center justify-between gap-y-2">
                <span class="flex items-center gap-1">
                    &copy; {{ current_year }} Nathan Surgenor
                    <span class="text-gray-600 mx-1">|</span>
                    Follow me on
                    <a href="https://github.com/ndsurgenor" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-200 transition-colors">GitHub</a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
                    <span class="mx-[2px]">&</span>
                    <a href="https://www.linkedin.com/in/nathan-surgenor/" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-200 transition-colors">LinkedIn</a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </span>
                <span class="flex items-center gap-1">
                    <a href="https://ko-fi.com/ndsurgenor" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-200 transition-colors mr-1">Support me via Ko-Fi</a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 4h1a4 4 0 1 1 0 8h-1"/><path d="M3 4h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="1" y1="18" x2="17" y2="18"/></svg>
                </span>
            </div>
        </div>
    </footer>

    {# SCRIPTS #}
    <script src="/assets/js/app.js"></script>
    {% block scripts %}{% endblock %}

</body>
</html>
