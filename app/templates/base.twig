<!DOCTYPE html>
<html lang="en" class="h-full">

{# HEAD #}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Surgenor Music{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Worship songs and resources from musician Nathan Surgenor.{% endblock %}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plaster&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/app.css">
    {% block head %}{% endblock %}
</head>

{# BODY #}
<body class="font-sans text-gray-900 bg-white flex flex-col min-h-full">

    {# NAVIGATION #}
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
        <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

            {# Branding #}
            <a href="/" class="flex items-center text-4xl tracking-tight" aria-label="Surgenor Music home">
                <span class="text-primary font-semibold mr-1">surgenor</span>
                <span class="text-secondary uppercase">m</span>
                <span class="text-primary">usic</span>
            </a>

            {# Desktop #}
            <ul class="hidden md:flex items-center gap-8">
                <li><a href="/" class="text-primary transition-colors font-medium">Home</a></li>
                <li><a href="/songs" class="text-primary transition-colors font-medium">Music</a></li>
                <li><a href="/contact" class="text-primary transition-colors font-medium">Contact</a></li>
            </ul>

            {# Mobile #}
            <button id="menu-toggle" class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </nav>

        {# Mobile menu #}
        <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
            <div class="max-w-6xl mx-auto px-6 py-4 space-y-3">
                <a href="/" class="block text-gray-700 hover:text-primary font-medium py-1">Home</a>
                <a href="/songs" class="block text-gray-700 hover:text-primary font-medium py-1">Music</a>
                <a href="/contact" class="block text-gray-700 hover:text-primary font-medium py-1">Contact</a>
            </div>
        </div>
    </header>

    {# FLASH MESSAGE #}
    {% if flash %}
    <div id="flash-message" class="{% if flash.type == 'success' %}bg-primary/10 border-primary/20 text-primary-700{% else %}bg-red-50 border-red-200 text-red-700{% endif %} border-b px-6 py-3 text-sm text-center font-medium">
        {{ flash.message }}
    </div>
    {% endif %}

    {# MAIN CONTENT #}
    <main class="flex-1">
        {% block content %}
        {% endblock %}
    </main>

    {# FOOTER #}
    <footer class="bg-white border-t border-gray-200 mt-16">
        <div class="max-w-6xl mx-auto px-6 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">

                <div>
                    <div class="flex items-center tracking-tight text-lg mb-3">
                        <span class="text-primary font-semibold mr-1">surgenor</span>
                        <span class="text-secondary uppercase">m</span>
                        <span class="text-primary">usic</span>
                    </div>
                    <p class="text-gray-500 text-sm leading-relaxed">Worship songs &amp; resources from musician Nathan Surgenor.</p>
                </div>

                <div>
                    <h4 class="font-semibold text-gray-900 text-sm mb-3">Music</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="/songs" class="hover:text-primary transition-colors">Song Catalogue</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="font-semibold text-gray-900 text-sm mb-3">Get in touch</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="/contact" class="hover:text-primary transition-colors">Contact Form</a></li>
                    </ul>
                </div>
            </div>

            <div class="pt-6 border-t border-gray-100 text-xs text-gray-400">
                &copy; {{ current_year }} Nathan Surgenor. All rights reserved.
            </div>
        </div>
    </footer>

    {# SCRIPTS #}
    <script src="/assets/js/app.js"></script>
    {% block scripts %}{% endblock %}

</body>
</html>
