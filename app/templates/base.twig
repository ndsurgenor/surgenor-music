<!DOCTYPE html>
<html lang="en" class="h-full">

{# HEAD #}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Surgenor Music{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Worship songs and resources from musician Nathan Surgenor.{% endblock %}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Questrial&family=Inter:wght@400;500;600;700&family=Plaster&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/app.css">
    {% block head %}{% endblock %}
</head>

{# BODY #}
<body class="font-sans text-charcoal bg-cream flex flex-col min-h-full">

    {# NAVIGATION #}
    <header class="bg-cream border-b border-gray-100 sticky top-0 z-50">
        <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

            {# Branding #}
            <a href="/" class="flex items-center font-hero text-primary text-2xl sm:text-3xl tracking-tight" aria-label="Surgenor Music home">
                <span class="font-semibold mr-1">surgenor</span>
                <span class="text-secondary uppercase tracking-tighter">m</span>usic
            </a>
`
            {# Desktop nav links + social icons #}
            <div class="hidden md:flex items-center gap-8">
                <ul class="flex items-center gap-8">
                    <li><a href="/" class="relative text-primary hover:text-charcoal transition-colors after:absolute after:left-0 after:h-[5px] after:-bottom-[8px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ current_path == '/' ? 'font-bold' : 'font-medium' }}">Home</a></li>
                    <li><a href="/songs" class="relative text-primary hover:text-charcoal transition-colors after:absolute after:left-0 after:h-[5px] after:-bottom-[8px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ current_path starts with '/songs' ? 'font-bold' : 'font-medium' }}">Music</a></li>
                    <li><a href="/contact" class="relative text-primary hover:text-charcoal transition-colors after:absolute after:left-0 after:h-[5px] after:-bottom-[8px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ current_path == '/contact' ? 'font-bold' : 'font-medium' }}">Contact</a></li>
                </ul>
                <div class="w-0.5 h-5 bg-gray-300"></div>
                <div class="flex items-center gap-3">
                    <a href="#" aria-label="Instagram" class="text-gray-500 hover:text-rose-400/85 transition-colors">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    </a>
                    <a href="#" aria-label="Spotify" class="text-gray-500 hover:text-green-400/85 transition-colors">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                    </a>
                    <a href="#" aria-label="YouTube" class="text-gray-500 hover:text-orange-500/85 transition-colors">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
                    </a>
                </div>
            </div>

            {# Mobile #}
            <button id="menu-toggle" class="md:hidden p-1 rounded-tr-lg border-2 border-accent text-accent bg-white hover:bg-gray-100 transition-colors transition-transform duration-[250ms]" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </nav>

        {# Mobile menu #}
        <div id="mobile-menu" class="md:hidden border-t border-gray-100 bg-cream">
            <div class="max-w-6xl mx-auto px-6 py-4 space-y-3 text-right">
                <a href="/" class="relative block w-fit ml-auto text-primary hover:text-charcoal transition-colors after:absolute after:bottom-0 after:left-0 after:h-[5px] after:-bottom-[3px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ current_path == '/' ? 'font-bold' : 'font-medium' }} py-1">Home</a>
                <a href="/songs" class="relative block w-fit ml-auto text-primary hover:text-charcoal transition-colors after:absolute after:bottom-0 after:left-0 after:h-[5px] after:-bottom-[3px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ current_path starts with '/songs' ? 'font-bold' : 'font-medium' }} py-1">Music</a>
                <a href="/contact" class="relative block w-fit ml-auto text-primary hover:text-charcoal transition-colors after:absolute after:bottom-0 after:left-0 after:h-[5px] after:-bottom-[3px] after:w-0 after:bg-accent/70 after:transition-all after:duration-300 hover:after:w-full {{ current_path == '/contact' ? 'font-bold' : 'font-medium' }} py-1">Contact</a>
            </div>
        </div>
    </header>

    {# FLASH MESSAGE #}
    {% if flash %}
    <div id="flash-message" class="{% if flash.type == 'success' %}bg-primary/10 border-primary/20 text-primary-700{% else %}bg-red-50 border-red-200 text-red-700{% endif %} border-b px-6 py-3 text-sm text-center font-medium">
        {{ flash.message }}
    </div>
    {% endif %}

    {# MAIN CONTENT #}
    <main class="flex-1">
        {% block content %}
        {% endblock %}
    </main>

    {# FOOTER #}
    <footer class="bg-cream border-t border-gray-200 mt-16">
        <div class="max-w-6xl mx-auto px-6 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">

                <div>
                    <div class="flex items-center font-hero tracking-tight text-lg mb-3">
                        <span class="text-primary font-semibold mr-1">surgenor</span>
                        <span class="text-secondary uppercase tracking-tighter">m</span>
                        <span class="text-primary">usic</span>
                    </div>
                    <p class="text-gray-500 text-sm leading-relaxed">Worship songs + resources for the local church.</p>
                </div>

                <div>
                    <h4 class="font-semibold text-gray-900 text-sm mb-3">Music</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="/songs" class="hover:text-primary transition-colors">Song Catalogue</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="font-semibold text-gray-900 text-sm mb-3">Get in touch</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="/contact" class="hover:text-primary transition-colors">Contact Form</a></li>
                    </ul>
                </div>
            </div>

            <div class="pt-6 border-t border-gray-100 text-xs text-gray-400">
                &copy; {{ current_year }} Nathan Surgenor. All rights reserved.
            </div>
        </div>
    </footer>

    {# SCRIPTS #}
    <script src="/assets/js/app.js"></script>
    {% block scripts %}{% endblock %}

</body>
</html>
