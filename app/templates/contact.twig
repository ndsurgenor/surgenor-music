{% extends 'base.twig' %}

{% block title %}Contact | Surgenor Music{% endblock %}
{% block meta_description %}Get in touch with Surgenor Music about worship music and resources.{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-6 py-12">

    {# HEADER & TEXT #}
    <div class="text-center mb-10">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Get in Touch</h1>
        <p class="text-gray-500 text-md">
            Have a question about a song or anything else?
            Send a message and we'll get back to you as soon as possible.
        </p>
    </div>

    {% if sent %}
    <div class="card border-primary/30 bg-primary/5 text-center py-10">
        <svg class="w-12 h-12 text-primary mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Message sent!</h2>
        <p class="text-gray-600 mb-6">Thanks for getting in touch. I'll respond as soon as I can.</p>
        <a href="/" class="btn-primary">Back to Home</a>
    </div>

    {% else %}

    {% if error %}
    <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700 mb-6">
        {{ error }}
    </div>
    {% endif %}

    {# FORM #}
    <form method="POST" action="/contact" class="space-y-6 card">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">

        <div>
            <label for="name" class="form-label">Name <span class="text-accent">*</span></label>
            <input type="text" id="name" name="name" value="{{ old.name ?? '' }}"
                   required class="form-input">
        </div>

        <div>
            <label for="email" class="form-label">Email <span class="text-accent">*</span></label>
            <input type="email" id="email" name="email" value="{{ old.email ?? '' }}"
                   required class="form-input">
        </div>

        <div>
            <label for="message_type" class="form-label">Message Type <span class="text-accent">*</span></label>
            <select id="message_type" name="message_type" required class="form-input">
                <option value="" disabled {{ old.message_type is not defined or old.message_type == '' ? 'selected' : '' }}>Please select…</option>
                <option value="Enquiry about a song"              {{ old.message_type ?? '' == 'Enquiry about a song'              ? 'selected' : '' }}>Enquiry about a song</option>
                <option value="Enquiry about a resource"          {{ old.message_type ?? '' == 'Enquiry about a resource'          ? 'selected' : '' }}>Enquiry about a resource</option>
                <option value="Copyright / licensing question"    {{ old.message_type ?? '' == 'Copyright / licensing question'    ? 'selected' : '' }}>Copyright / licensing question</option>
                <option value="Website problem"                   {{ old.message_type ?? '' == 'Website problem'                   ? 'selected' : '' }}>Website problem</option>
                <option value="Feedback or suggestion"           {{ old.message_type ?? '' == 'Feedback or suggestion'            ? 'selected' : '' }}>Feedback or suggestion</option>
                <option value="General enquiry"                   {{ old.message_type ?? '' == 'General enquiry'                   ? 'selected' : '' }}>General enquiry</option>
            </select>
        </div>

        <div>
            <label for="message" class="form-label">Message <span class="text-accent">*</span></label>
            <textarea id="message" name="message" rows="4" required class="form-input"></textarea>
        </div>

        <button type="submit" class="btn-primary w-full justify-center">Send Message</button>
    </form>

    <p class="text-center text-sm text-gray-500 mt-10">
        If you are having trouble with the form, please email us directly at
        <a href="mailto:info@surgenormusic.com" class="text-primary hover:underline">info@surgenormusic.com</a>
        to let us know and to send your message.
    </p>
    {% endif %}

</div>
{% endblock %}
