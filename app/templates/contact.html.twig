{% extends 'base.html.twig' %}

{% block title %}Contact — Surgenor Music{% endblock %}
{% block meta_description %}Get in touch with Nathan Surgenor about worship music and resources.{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-6 py-12">

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Get in Touch</h1>
    <p class="text-gray-500 mb-10">Have a question about a song or resource? Send a message and I'll get back to you.</p>

    {% if sent %}
    <div class="card border-primary/30 bg-primary/5 text-center py-10">
        <svg class="w-12 h-12 text-primary mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Message sent!</h2>
        <p class="text-gray-600 mb-6">Thanks for getting in touch. I'll respond as soon as I can.</p>
        <a href="/" class="btn-primary">Back to Home</a>
    </div>

    {% else %}

    {% if error %}
    <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700 mb-6">
        {{ error }}
    </div>
    {% endif %}

    <form method="POST" action="/contact" class="space-y-6 card">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">

        <div>
            <label for="name" class="form-label">Name</label>
            <input type="text" id="name" name="name" value="{{ old.name ?? '' }}"
                   required class="form-input" placeholder="Your name">
        </div>

        <div>
            <label for="email" class="form-label">Email address</label>
            <input type="email" id="email" name="email" value="{{ old.email ?? '' }}"
                   required class="form-input" placeholder="you@example.com">
        </div>

        <div>
            <label for="message" class="form-label">Message</label>
            <textarea id="message" name="message" rows="6"
                      required class="form-input resize-none"
                      placeholder="Your message…">{{ old.message ?? '' }}</textarea>
        </div>

        <button type="submit" class="btn-primary w-full justify-center">Send Message</button>
    </form>
    {% endif %}

</div>
{% endblock %}
