APP_ENV=development
APP_URL=http://localhost

# Database — path is relative to the app/ directory
DB_PATH=database/surgenor.sqlite

# Admin password — generate with: php app/generate-password.php
ADMIN_PASSWORD_HASH=

# Contact form SMTP settings
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=hello@surgenormusic.com
MAIL_FROM_NAME="Surgenor Music"
MAIL_TO=hello@surgenormusic.com
